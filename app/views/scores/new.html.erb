
<div class="page__content subheader">
	<h1 class="pull-left"><%= (@product.is_assessed?) ? "Updating" : "Adding" %> Maturity Score for <%= @product.name %></h1>
	<%# The HTML5 form= attribute submits the score form (below) natively, so no
	    JS is needed for this header button. %>
	<button id="form-submitter" type="submit" form="score-form" class="button button--cta pull-right"> Save Score </button>
	<%= link_to 'Cancel', product_path(@product), class: "button button--dngr pull-right" %>
</div>

<% if CONFIGS[:enable_repo_assessment] %>
<div class="page__content main-content">
	<%# Point the model at a repository to auto-fill the capabilities across every
	    maturity model. The assessment reads the whole repo and runs in the
	    background (it takes minutes), so this page polls until it's done. %>
	<%= form_with url: new_product_score_path(@product), method: :get do %>
		<%= text_field_tag :repo, params[:repo], placeholder: 'Local path or git URL (https/ssh)',
			class: 'form-control', style: 'max-width:420px; display:inline-block; margin-right:8px' %>
		<%= submit_tag 'Assess from repository', class: 'button button--cta' %>
	<% end %>

	<% if @scan&.in_progress? %>
		<div class="alert alert-info" data-controller="repo-scan"
			data-repo-scan-status-url-value="<%= scan_status_product_scores_path(@product, id: @scan.id) %>"
			data-repo-scan-interval-value="2500">
			<p><strong>Assessing <code><%= @scan.repo %></code>…</strong> reading the whole repository and scoring it against every maturity model. This takes a few minutes — you can leave this page open.</p>
			<div style="height:10px; background:#21222c; border-radius:5px; overflow:hidden">
				<div data-repo-scan-target="bar" style="height:10px; width:<%= @scan.progress %>%; background:#bd93f9; transition:width .4s"></div>
			</div>
			<p style="margin-top:6px"><span data-repo-scan-target="label"><%= @scan.progress %>%</span>
				&middot; <%= link_to 'or fill it in manually', new_product_score_path(@product) %></p>
		</div>
	<% elsif @scan&.failed? %>
		<div class="alert alert-danger">
			<%= @scan.error %>
			&middot; <%= link_to 'Try again', new_product_score_path(@product, repo: @scan.repo, rescan: 1) %>
		</div>
	<% elsif @scan&.complete? %>
		<% total = @scan.models.sum { |m| m["findings"].size } %>
		<div class="alert alert-success">
			<p>Pre-filled <strong><%= total %></strong> capabilities across <%= @scan.models.size %> maturity model<%= 's' unless @scan.models.size == 1 %> from
				<code><%= @scan.source %></code>. Review them, complete the rest, then Save.</p>
			<% @scan.models.each do |model| %>
				<% next if model["findings"].empty? %>
				<p style="margin:.6em 0 .2em"><strong><%= model["name"] %></strong> — <%= model["findings"].size %> detected</p>
				<ul>
					<% model["findings"].each do |f| %>
						<li><strong><%= f["title"] %></strong> &rarr; Level <%= f["level"] %>
							<small>(<%= f["note"] %>)</small></li>
					<% end %>
				</ul>
			<% end %>
		</div>
	<% end %>
</div>
<% end %>

<% unless @scan&.in_progress? %>
	<div class="page__content main-content progressive-form-container">
		<%= render 'form' %>
	</div>
<% end %>
