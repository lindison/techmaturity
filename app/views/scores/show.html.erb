<% capabilities = @framework.capabilities.to_a %>
<% capability_labels = capabilities.map(&:name) %>
<% capability_values = @assessment.capability_values %>
<% org_capability_values = Assessment.org_capability_values(@framework) %>
<% category_labels = @framework.dimensions.order(:position).map(&:name) %>

<div class="page__content subheader">
	<h1 class="pull-left"><%= @framework.name %> Score for <%= @product.name %></h1>
	<%= link_to 'Show All Scores', product_scores_path(@product), class: "button button--cta pull-right" %>
</div>

<% unless notice.nil? %>
	<div class="alert alert-<%=notice["type"]%> alert-dismissable">
		<a href="#" class="close" data-dismiss="alert" aria-label="close">&times;</a>
		<p id="notice"><%= notice["message"] %></p>
	</div>
<% end %>

<div class="score-sidebar">
	<div class="score-sidebar-item">
		<div class="score-sidebar-title"><p> Readiness Score </p></div>
		<div class="score-sidebar-value"><p><%= @assessment.total.round(2) %>%</p></div>
	</div>
	<div class="score-sidebar-item">
		<canvas id="bar-score-graph"></canvas>
	</div>
</div>

<div class="score-main">
	<div class="score-main-title">
		Score Details <span data-tooltip-position="right" data-tooltip="<%= @assessment.comment.presence || 'No comments on this score' %>">&#x24D8;</span>
	</div>

	<div class="score-main-sub-title">
		<a onclick="openSlider('slider-data')"> SHOW DETAILED SCORE DESCRIPTION </a>
		<br>
		<p>Last Updated on: <%= @assessment.created_at.strftime("%B %d, %Y") %></p>
	</div>

	<div class="score-main-graph active">
		<canvas id="line-score-graph"></canvas>
	</div>
</div>

<div class="slider-data">
	<div class="title"> <h1> Score Details </h1> </div>
	<div class="content">
		<table class="table table-hover table-bordered">
			<thead>
				<tr>
					<th bgcolor="#D0006F" style="color: #FFF"> Title </th>
					<th bgcolor="#D0006F" style="color: #FFF"> Score </th>
					<th bgcolor="#D0006F" style="color: #FFF"> Current Score Description </th>
					<th bgcolor="#D0006F" style="color: #FFF"> Next Level Description </th>
				</tr>
			</thead>
			<% capabilities.each_with_index do |capability, index| %>
				<% value = capability_values[index].to_i %>
				<tr>
					<td><%= capability.name %></td>
					<td><%= value %></td>
					<td><%= capability.level(value)&.description if value.positive? %></td>
					<td><%= capability.level(value + 1)&.description if value < 4 %></td>
				</tr>
			<% end %>
		</table>
	</div>
</div>

<%= javascript_tag do %>
	window.onChartReady(function() {
	window.renderChart("line-score-graph", {
		type: 'line',
		data: {
			labels: <%= raw capability_labels.to_json %>,
			datasets: [{
				label: "Capability Scores",
				data: <%= raw capability_values.to_json %>,
				backgroundColor: ['rgba(54, 162, 235, 0.2)'], borderColor: '#000', borderWidth: 1,
				pointBackgroundColor: "#fff", pointHoverBackgroundColor: "rgba(75,192,192,1)", pointRadius: 3
			},{
				label: "Organizational Average",
				data: <%= raw org_capability_values.to_json %>,
				fill: false, backgroundColor: '#d0006f', borderColor: '#d0006f', borderWidth: 1, pointRadius: 0
			},{
				type: 'line', label: 'Category Score',
				data: <%= raw @assessment.expanded_dimension_values.to_json %>,
				borderWidth: 1, tension: 0, pointRadius: 0
			}]
		},
		options:{
			layout: { padding: { bottom: 30 } },
			scales: {
				y: { min: 0, max: 4, beginAtZero: true, ticks: { stepSize: 1 } },
				x: { ticks: { display: true, autoSkip: false, minRotation: 90 } }
			}
		}
	});

	window.renderChart("bar-score-graph", {
		type: 'bar',
		data: {
			labels: <%= raw category_labels.to_json %>,
			datasets: [{
				label: "Average Category Score",
				data: <%= raw @assessment.dimension_values.to_json %>,
				backgroundColor: ['rgba(223,243,251,0.4)', 'rgba(191, 230, 247, 0.4)', 'rgba(128,206, 239, 0.4)', 'rgba(0, 151, 211, 0.4)', 'rgba(0, 117, 167, 0.4)'],
				borderColor: '#000000', borderWidth: 1
			},{
				label: "Organizational Average", type: 'line', fill: false,
				data: <%= raw Assessment.org_dimension_values(@framework).to_json %>,
				borderColor: '#d0006f', backgroundColor: '#d0006f', borderWidth: 1
			}]
		},
		options:{
			plugins: { title: { display: true, text: 'Category Average' }, legend: { display: false } },
			scales: { y: { min: 0, max: 4, beginAtZero: true, ticks: { stepSize: 1 } }, x: { display: false } }
		}
	});
	});
<% end %>
